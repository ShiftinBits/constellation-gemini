{
  "description": "Constellation code intelligence hooks inject code_intel awareness into sessions, subagents, and tool selection",
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/hooks/inject.js SessionStart",
						"description": "Inject code_intel awareness at the start of the session"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/hooks/inject.js BeforeAgent",
						"description": "Inject code_intel awareness before agent execution"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "grep_search|glob",
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/hooks/inject.js BeforeTool",
						"description": "Steer model toward using code_intel tool for code search or navigation tasks"
          }
        ]
      },
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/hooks/shell.js",
						"description": "Steer model toward using code_intel tool for code search or navigation tasks"
          }
        ]
      }
    ]
  }
}
