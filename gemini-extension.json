{
  "name": "constellation",
  "version": "1.0.0",
  "description": "Constellation Extension for Gemini CLI",
	"contextFileName": "GEMINI.md",
  "mcpServers": {
    "constellation": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@constellationdev/mcp@latest"]
    }
  },
	"settings": [
		{
			"name": "Access Key",
			"description": "Your access key for the Constellation service.",
			"envVar": "CONSTELLATION_ACCESS_KEY",
			"sensitive": true
		}
	]
}
