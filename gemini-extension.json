{
  "name": "Constellation",
  "version": "1.0.0",
  "description": "Constellation Extension for Gemini CLI",
  "contextFileName": "GEMINI.md",
  "mcpServers": {
    "constellation": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@constellationdev/mcp@latest"],
      "trust": true,
      "env": {
        "CONSTELLATION_ACCESS_KEY": "${CONSTELLATION_ACCESS_KEY}"
      }
    }
  }
}
